---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pagina nao encontrada" description="A pagina que voce procura nao existe.">
  <div class="text-center py-24 max-w-md mx-auto">
    <p class="font-serif text-[8rem] font-black leading-none text-border-dark/10 mb-4 animate-fade-up">
      404
    </p>
    <h1 class="font-serif text-2xl font-bold text-primary mb-3 animate-fade-up" style="animation-delay: 80ms">
      Pagina nao encontrada
    </h1>
    <p class="text-text-muted mb-10 animate-fade-up" style="animation-delay: 160ms">
      O artigo que voce procura nao existe ou foi removido da publicacao.
    </p>
    <div class="animate-fade-up" style="animation-delay: 240ms">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-xs uppercase tracking-widest font-semibold text-accent hover:text-accent-light transition-colors duration-200 group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:-translate-x-1">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Voltar a pagina inicial
      </a>
    </div>
  </div>
</BaseLayout>
