---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = allPosts;
---

<BaseLayout
  title="Leon Porte"
  description="Blog pessoal sobre tecnologia, desenvolvimento de software e aprendizados do dia a dia."
>
  <!-- Hero / About -->
  <section class="pb-10 mb-2 animate-fade-up">
    <p class="text-xs uppercase tracking-[0.2em] text-text-light font-semibold mb-6">Sobre</p>
    <div class="flex flex-col sm:flex-row gap-8 items-start">
      <!-- Photo -->
      <div class="shrink-0 relative">
        <div class="w-36 h-44 sm:w-44 sm:h-52 overflow-hidden">
          <img
            src="/images/profile.jpg"
            alt="Leon Porte"
            class="w-full h-full object-cover object-top grayscale hover:grayscale-0 transition-all duration-700"
          />
        </div>
        <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-accent"></div>
      </div>
      <!-- Text -->
      <div class="max-w-xl">
        <p class="font-serif text-xl sm:text-2xl leading-relaxed text-primary mb-4">
          Dizem que só domina o conhecimento aquele que é capaz de transmiti-lo.
        </p>
        <p class="text-text-muted leading-relaxed text-[0.95rem]">
          Este blog é o meu <em class="text-accent not-italic font-semibold">laboratório de autoafirmação intelectual</em>.
          Aqui, transformo 6 anos de mercado e desafios reais em .NET e
          frameworks modernos (Vue, Angular, React) em artigos práticos. É o
          registro da minha evolução técnica, onde cada post é um passo para
          consolidar o que sei e explorar o que ainda não descobri.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured post -->
  {featured && (
    <section class="mb-2">
      <PostCard
        title={featured.data.title}
        description={featured.data.description}
        pubDate={featured.data.pubDate}
        slug={featured.id}
        tags={featured.data.tags}
        featured={true}
      />
    </section>
  )}

  <!-- Rest of posts -->
  {rest.length > 0 && (
    <section>
      <div class="rule-top pt-5 mb-2">
        <p class="text-xs uppercase tracking-[0.2em] text-text-light font-semibold">
          Mais artigos
        </p>
      </div>
      <div class="stagger">
        {rest.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
            index={i + 2}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
