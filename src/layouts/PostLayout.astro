---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;

const formattedDate = frontmatter.pubDate.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = frontmatter.updatedDate?.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const readingTime = '5 min de leitura';
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="max-w-3xl mx-auto">
    <!-- Breadcrumb -->
    <nav class="mb-8 animate-fade-up">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-xs uppercase tracking-widest text-text-muted hover:text-accent transition-colors duration-200 group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:-translate-x-1">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Voltar ao inicio
      </a>
    </nav>

    <!-- Article header -->
    <header class="mb-10 animate-fade-up" style="animation-delay: 100ms">
      <!-- Category tags -->
      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {frontmatter.tags.map((tag) => (
            <span class="text-xs font-semibold uppercase tracking-widest text-accent">
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Title -->
      <h1 class="font-serif text-4xl sm:text-5xl font-black leading-[1.1] tracking-tight text-primary mb-5">
        {frontmatter.title}
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-text-muted leading-relaxed mb-6 max-w-2xl">
        {frontmatter.description}
      </p>

      <!-- Meta line -->
      <div class="flex flex-wrap items-center gap-3 text-xs text-text-light uppercase tracking-wider pb-6 border-b-2 border-border-dark">
        <time datetime={frontmatter.pubDate.toISOString()}>
          {formattedDate}
        </time>
        <span>&middot;</span>
        <span>{readingTime}</span>
        {formattedUpdatedDate && (
          <>
            <span>&middot;</span>
            <span>Atualizado em {formattedUpdatedDate}</span>
          </>
        )}
      </div>
    </header>

    <!-- Article body -->
    <div class="prose animate-fade-up" style="animation-delay: 200ms">
      <slot />
    </div>

    <!-- End mark -->
    <div class="mt-12 mb-8 text-center">
      <span class="font-serif text-2xl text-border select-none">&#9632;</span>
    </div>
  </article>
</BaseLayout>
