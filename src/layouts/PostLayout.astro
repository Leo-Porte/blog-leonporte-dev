---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;

const formattedDate = frontmatter.pubDate.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = frontmatter.updatedDate?.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article>
    <header class="mb-10 animate-fade-up">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-primary transition-all duration-300 mb-7 group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:-translate-x-1">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Voltar
      </a>

      <div class="flex flex-col gap-4">
        <time datetime={frontmatter.pubDate.toISOString()} class="text-sm text-text-muted font-medium">
          {formattedDate}
        </time>

        <h1
          class="text-3xl sm:text-4xl font-extrabold tracking-tight text-text leading-tight"
          transition:name={`post-title-${frontmatter.title}`}
        >
          {frontmatter.title}
        </h1>

        <p class="text-lg text-text-muted leading-relaxed">
          {frontmatter.description}
        </p>

        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {frontmatter.tags.map((tag) => (
              <span class="text-xs font-medium text-primary-light bg-primary/8 border border-primary/15 px-2.5 py-1 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}

        {formattedUpdatedDate && (
          <p class="text-xs text-text-muted italic">
            Atualizado em {formattedUpdatedDate}
          </p>
        )}
      </div>

      <div class="mt-8 h-px bg-gradient-to-r from-primary/30 via-border to-transparent"></div>
    </header>

    <div class="prose animate-fade-up" style="animation-delay: 150ms">
      <slot />
    </div>
  </article>
</BaseLayout>
