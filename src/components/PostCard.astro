---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  index?: number;
  featured?: boolean;
}

const { title, description, pubDate, slug, tags = [], index, featured = false } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

{featured ? (
  <article class="group animate-fade-up">
    <a href={`/posts/${slug}`} class="block">
      <div class="rule-accent pt-5 pb-8">
        <span class="text-xs font-sans uppercase tracking-widest text-accent font-semibold">
          Destaque
        </span>
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-primary leading-tight mt-3 mb-3 group-hover:text-accent transition-colors duration-300">
          {title}
        </h2>
        <p class="text-text-muted leading-relaxed text-base max-w-2xl mb-4">
          {description}
        </p>
        <div class="flex items-center gap-3 text-xs text-text-light">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          {tags.length > 0 && (
            <>
              <span>&middot;</span>
              <span class="uppercase tracking-wider">{tags.join(', ')}</span>
            </>
          )}
        </div>
      </div>
    </a>
  </article>
) : (
  <article class="group animate-fade-up">
    <a href={`/posts/${slug}`} class="block">
      <div class="border-t border-border py-5 flex gap-5 items-start">
        {typeof index === 'number' && (
          <span class="font-serif text-4xl font-bold text-border leading-none mt-0.5 hidden sm:block select-none">
            {String(index).padStart(2, '0')}
          </span>
        )}
        <div class="flex-1 min-w-0">
          <h3 class="font-serif text-xl font-bold text-primary leading-snug mb-1.5 group-hover:text-accent transition-colors duration-300">
            {title}
          </h3>
          <p class="text-text-muted text-sm leading-relaxed mb-2 line-clamp-2">
            {description}
          </p>
          <div class="flex items-center gap-3 text-xs text-text-light">
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
            {tags.length > 0 && (
              <>
                <span>&middot;</span>
                <span class="uppercase tracking-wider">{tags.join(', ')}</span>
              </>
            )}
          </div>
        </div>
        <span class="text-text-light opacity-0 group-hover:opacity-100 transition-opacity duration-300 mt-1 hidden sm:inline">
          &rarr;
        </span>
      </div>
    </a>
  </article>
)}
