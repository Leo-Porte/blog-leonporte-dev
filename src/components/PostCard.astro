---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group animate-fade-up">
  <a
    href={`/posts/${slug}`}
    class="block py-6 -mx-4 px-4 rounded-xl transition-all duration-300 hover:bg-surface-elevated hover:shadow-[0_2px_20px_rgba(109,40,217,0.06)] hover:-translate-y-0.5"
  >
    <div class="flex flex-col gap-2.5">
      <div class="flex items-center gap-3">
        <time datetime={pubDate.toISOString()} class="text-sm text-text-muted">
          {formattedDate}
        </time>
        <div class="h-px flex-1 bg-border/50"></div>
      </div>

      <h2 class="text-xl font-bold text-text group-hover:text-primary transition-colors duration-300 tracking-tight">
        {title}
        <span class="inline-block ml-1 opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 text-primary">
          &rarr;
        </span>
      </h2>

      <p class="text-text-muted leading-relaxed">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-0.5">
          {tags.map((tag) => (
            <span class="text-xs font-medium text-primary-light bg-primary/8 border border-primary/15 px-2.5 py-0.5 rounded-full transition-colors duration-200 group-hover:bg-primary/12">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
