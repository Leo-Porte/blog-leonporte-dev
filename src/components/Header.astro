---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/posts', label: 'Posts' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="border-b border-border/60 bg-surface/80 backdrop-blur-md sticky top-0 z-50"
  transition:animate="none"
>
  <nav class="mx-auto max-w-3xl px-6 py-4 flex items-center justify-between">
    <a
      href="/"
      class="group flex items-center gap-1.5 text-xl font-bold text-text transition-all duration-300"
    >
      <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-primary text-white text-sm font-extrabold transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3">
        L
      </span>
      <span class="transition-colors duration-300 group-hover:text-primary">
        leon<span class="text-primary">porte</span>
      </span>
    </a>

    <ul class="flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium link-underline transition-colors duration-300',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-primary'
                : 'text-text-muted hover:text-text',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/rss.xml"
          target="_blank"
          class="text-text-muted hover:text-accent transition-all duration-300 hover:scale-110 inline-block"
          title="RSS Feed"
          aria-label="RSS Feed"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9" />
            <path d="M4 4a16 16 0 0 1 16 16" />
            <circle cx="5" cy="19" r="1" />
          </svg>
        </a>
      </li>
    </ul>
  </nav>
</header>
