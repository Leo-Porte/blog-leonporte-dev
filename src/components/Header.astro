---
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/posts', label: 'Arquivo' },
];

const currentPath = Astro.url.pathname;

const today = new Date().toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<header class="sticky top-0 z-50 bg-surface/95 backdrop-blur-sm" transition:animate="none">
  <!-- Top thin rule -->
  <div class="h-[3px] bg-accent"></div>

  <div class="mx-auto max-w-4xl px-6">
    <!-- Masthead -->
    <div class="py-5 text-center border-b border-border-dark">
      <a href="/" class="inline-block group">
        <h1 class="font-serif text-3xl sm:text-4xl font-black tracking-tight text-primary transition-colors">
          Leon Porte
        </h1>
      </a>
      <p class="text-xs text-text-muted mt-1 tracking-widest uppercase font-sans">
        Tecnologia &middot; Arquitetura &middot; Software
      </p>
    </div>

    <!-- Nav bar -->
    <nav class="flex items-center justify-between py-3 border-b border-border text-sm">
      <ul class="flex items-center gap-5">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'font-medium uppercase tracking-wider text-xs transition-colors duration-200',
                currentPath === href || (href !== '/' && currentPath.startsWith(href))
                  ? 'text-accent'
                  : 'text-text-muted hover:text-text',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-4">
        <span class="text-xs text-text-light hidden sm:inline">{today}</span>
        <a
          href="/rss.xml"
          target="_blank"
          class="text-text-muted hover:text-accent transition-colors duration-200"
          title="RSS Feed"
          aria-label="RSS Feed"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9" />
            <path d="M4 4a16 16 0 0 1 16 16" />
            <circle cx="5" cy="19" r="1" />
          </svg>
        </a>
      </div>
    </nav>
  </div>
</header>
