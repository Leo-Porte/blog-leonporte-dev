---
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto">
  <div class="mx-auto max-w-4xl px-6">
    <!-- Triple rule -->
    <div class="border-t border-border pt-0.5">
      <div class="border-t-2 border-border-dark"></div>
    </div>

    <div class="py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-text-muted">
      <p>&copy; {currentYear} Leon Porte</p>
      <div class="flex items-center gap-5">
        <a
          href="https://github.com/Leo-Porte"
          target="_blank"
          rel="noopener noreferrer"
          class="uppercase tracking-wider hover:text-text transition-colors duration-200"
        >
          GitHub
        </a>
        <span class="text-border">|</span>
        <a
          href="https://www.linkedin.com/in/leonardo-miguel-porte"
          target="_blank"
          rel="noopener noreferrer"
          class="uppercase tracking-wider hover:text-text transition-colors duration-200"
        >
          LinkedIn
        </a>
        <span class="text-border">|</span>
        <a
          href="/rss.xml"
          target="_blank"
          class="uppercase tracking-wider hover:text-text transition-colors duration-200"
        >
          RSS
        </a>
      </div>
    </div>
  </div>
</footer>
